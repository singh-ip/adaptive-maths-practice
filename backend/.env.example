APP_NAME="Adaptive Maths Practice API"
APP_ENV=production
APP_KEY=
# Never enable APP_DEBUG=true in production — stack traces expose internal paths and config
APP_DEBUG=false
APP_URL=http://localhost:8000

# Use stderr for serverless (Lambda writes stdout/stderr to CloudWatch automatically)
LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=adaptive_maths
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_STORE=array

OLLAMA_BASE_URL=http://ollama:11434

OLLAMA_MODEL=llama3.2

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
